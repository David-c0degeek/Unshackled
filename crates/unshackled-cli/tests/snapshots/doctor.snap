Unshackled <version>

platform:
  os:   <os>
  arch: <arch>

config search paths:
  user: <config-home>/unshackled/config.toml (missing)
  project: <workspace>/.unshackled.toml (present)

providers:
  local: credential UNSHACKLED_LOCAL_API_KEY not set
  openai: credential OPENAI_API_KEY not set
  anthropic: credential ANTHROPIC_API_KEY not set

tools:
  git (git): available
  ripgrep (rg): available

workspace trust: unknown (evaluated when a session starts)
